# =====================================================================
# .env.example — commit this file. Copy to .env.local (web) / .env (root)
# Real secrets NEVER commit.
# =====================================================================

# --- Mantle ---
MANTLE_SEPOLIA_RPC=https://rpc.sepolia.mantle.xyz
MANTLE_EXPLORER=https://explorer.sepolia.mantle.xyz
MANTLE_EXPLORER_API_KEY=

# --- Deploy ---
# Use a brand-new wallet for development. NEVER use your personal wallet.
DEPLOYER_PRIVATE_KEY=0x

# --- Data ---
POLYGON_IO_API_KEY=
PYTH_HERMES_URL=https://hermes.pyth.network

# --- DB (Supabase) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- AI ---
# Provider for routing narration. claude|zai. Unset = auto (Claude if its key
# is set, else Z.ai). README: Claude on dev, Z.ai (Mantle sponsor) on the demo.
LLM_PROVIDER=
ANTHROPIC_API_KEY=
# Z.ai (OpenAI-compatible). Defaults: base https://api.z.ai/api/paas/v4, model glm-4.6.
# Override if your account uses a different endpoint/model.
ZAI_API_KEY=
ZAI_BASE_URL=
ZAI_MODEL=

# --- Web (Next.js public) ---
NEXT_PUBLIC_CHAIN_ID=5003
NEXT_PUBLIC_CHAIN_NAME=Mantle Sepolia
NEXT_PUBLIC_RPC_URL=https://rpc.sepolia.mantle.xyz
NEXT_PUBLIC_EXPLORER_URL=https://explorer.sepolia.mantle.xyz
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=

# --- Cron auth (used by /api/cron/* routes) ---
CRON_SECRET=
