# apps/web/.env.example
#
# Copy to .env.local and fill values. NEVER commit .env.local.
# Vercel: set the same vars in Project Settings → Environment Variables.

# --- Data sources (T4 snapshot cron) ---
POLYGON_IO_API_KEY=
PYTH_HERMES_URL=https://hermes.pyth.network

# --- Supabase (snapshot store, decision log, settlement history) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
# SERVICE ROLE: server-only. Used by cron handler. Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=

# --- AI (T2 distribution routing reasoning) ---
ANTHROPIC_API_KEY=
# ZAI_API_KEY=          # optional, for demo with sponsor

# --- Cron auth (Vercel Cron or external schedulers) ---
# Header: `x-cron-secret: <value>` OR `Authorization: Bearer <value>`
CRON_SECRET=

# --- Chain (Mantle Sepolia) ---
NEXT_PUBLIC_CHAIN_ID=5003
NEXT_PUBLIC_CHAIN_NAME="Mantle Sepolia"
NEXT_PUBLIC_RPC_URL=https://rpc.sepolia.mantle.xyz
NEXT_PUBLIC_EXPLORER_URL=https://sepolia.mantlescan.xyz
